# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection string ──────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Local example (requires a running PostgreSQL instance):
DATABASE_URL=postgresql://postgres:password@localhost:5432/tailoring_dev

# ── Session / JWT signing secret ─────────────────────────────────────────────
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_64_chars

# ── (Optional) Node environment ───────────────────────────────────────────────
# Set to "development" for local dev, "production" for prod builds.
NODE_ENV=development
